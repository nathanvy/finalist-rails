<div class="lineitem item-row">
  <%= form_with model: [list, item] do |f| %>
    <%= f.text_field :body, id: dom_id(item, :body), autofocus: true %>
    <%= f.submit "Save" %>
  <% end %>

  <%= button_to "Cancel",
               list_item_path(list, item),
               method: :get,
               data: { turbo_frame: dom_id(item) } %>
</div>
